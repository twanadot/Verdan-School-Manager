<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Console appender with MDC fields for request correlation -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} %X{requestId:--} %X{user:--} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File appender with full timestamps and MDC for production debugging -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/verdan.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/verdan-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} [req=%X{requestId:-none}] [user=%X{user:-anonymous}] - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Application loggers -->
    <logger name="no.example.verdan" level="INFO"/>
    <logger name="no.example.verdan.api" level="DEBUG"/>
    <logger name="no.example.verdan.service" level="DEBUG"/>
    <logger name="no.example.verdan.security" level="INFO"/>

    <!-- Hibernate: reduce noise -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/>

    <!-- Javalin -->
    <logger name="io.javalin" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
