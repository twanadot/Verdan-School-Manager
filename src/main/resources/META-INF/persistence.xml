<?xml version="1.0" encoding="UTF-8"?>
<persistence
    xmlns="https://jakarta.ee/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
    version="3.1">

  <persistence-unit name="verdanPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

    <class>no.example.verdan.model.User</class>
    <class>no.example.verdan.model.Grade</class>
    <class>no.example.verdan.model.Subject</class>
    <class>no.example.verdan.model.SubjectAssignment</class>
    <class>no.example.verdan.model.Program</class>
    <class>no.example.verdan.model.ProgramMember</class>
    <class>no.example.verdan.model.AdmissionPeriod</class>
    <class>no.example.verdan.model.AdmissionRequirement</class>
    <class>no.example.verdan.model.Application</class>
    <class>no.example.verdan.model.Attendance</class>
    <class>no.example.verdan.model.Room</class>
    <class>no.example.verdan.model.Booking</class>
    <class>no.example.verdan.model.Institution</class>
    <class>no.example.verdan.model.ChatRoom</class>
    <class>no.example.verdan.model.ChatMessage</class>
    <class>no.example.verdan.model.ChatMember</class>
    <class>no.example.verdan.model.ChatAttachment</class>
    <class>no.example.verdan.model.ChatReaction</class>
    <class>no.example.verdan.model.UserStatus</class>
    <class>no.example.verdan.model.PortalAnnouncement</class>
    <class>no.example.verdan.model.PortalComment</class>
    <class>no.example.verdan.model.PortalFolder</class>
    <class>no.example.verdan.model.PortalFile</class>
    <class>no.example.verdan.model.PortalSubmission</class>

    <exclude-unlisted-classes>true</exclude-unlisted-classes>

    <properties>
      <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <!-- Allows overriding via environment variables (for Docker) -->
      <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://${env.DB_HOST:localhost}:3306/verdan_db?createDatabaseIfNotExist=true"/>
      <property name="jakarta.persistence.jdbc.user" value="${env.DB_USER:root}"/>
      <property name="jakarta.persistence.jdbc.password" value="${env.DB_PASS:secret}"/>

      <property name="hibernate.hbm2ddl.auto" value="update"/>
      <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
      
      <property name="hibernate.show_sql" value="false"/>
      <property name="hibernate.format_sql" value="true"/>
    </properties>
  </persistence-unit>
</persistence>